{# Rendered by wazuh_server. The output.elasticsearch.password value comes from the
   filebeat keystore (key WAZUH_INDEXER_PASSWORD), populated by a separate task in
   present_redhat.yml. The role refuses to write the plaintext password into this file
   so disk forensics, backups, and root-process reads see only the ${VAR} reference. #}
# Wazuh - Filebeat configuration file (rendered by ansible)
output.elasticsearch:
  hosts: ["{{ __indexer_host__ }}:9200"]
  protocol: https
  username: "{{ __filebeat_user__ }}"
  password: "${WAZUH_INDEXER_PASSWORD}"
  ssl.certificate_authorities:
    - {{ config.filebeat.certs_dir }}/root-ca.pem
  ssl.certificate: "{{ config.filebeat.certs_dir }}/filebeat.pem"
  ssl.key: "{{ config.filebeat.certs_dir }}/filebeat-key.pem"
{# The wazuh index template is pre-loaded by the wazuh_server role using the admin
   cert. This lets us drop `indices:admin/template/put` from the filebeat writer RBAC
   role — Filebeat's bearer credential only needs data-write perms. #}
setup.template.enabled: false
setup.ilm.enabled: false

filebeat.config.modules:
  path: ${path.config}/modules.d/*.yml
  reload.enabled: false

logging.level: info
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat
  keepfiles: 7
  permissions: 0644

logging.metrics.enabled: false

seccomp:
  default_action: allow
  syscalls:
    - action: allow
      names:
        - rseq
