# =============================================================================
# EditorConfig — https://editorconfig.org
# =============================================================================
# Enforces consistent formatting across all editors without requiring plugin
# configuration. Supported natively in VS Code, JetBrains, Vim, Emacs, etc.
# =============================================================================

root = true

# ---------------------------------------------------------------------------
# All files
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# ---------------------------------------------------------------------------
# YAML (Ansible playbooks, roles, vars)
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Jinja2 templates
# ---------------------------------------------------------------------------
[*.j2]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Markdown — preserve trailing spaces (line breaks) but trim blank lines
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ---------------------------------------------------------------------------
# JSON (release-please manifest, pre-commit config)
# ---------------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Makefile — tabs required
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ---------------------------------------------------------------------------
# Terraform / HCL (proxmox.tfvars, aws.tfvars)
# ---------------------------------------------------------------------------
[*.{tf,tfvars,hcl}]
indent_style = space
indent_size = 2
