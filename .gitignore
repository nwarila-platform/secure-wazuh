# --------------------------------------------------------------------------- #
#  Docs tooling (layout checker).
# --------------------------------------------------------------------------- #
!/tools/
!/tools/check_docs_layout.py

# --------------------------------------------------------------------------- #
#  Ansible — product roles + playbooks + inventory (loader/shared roles composed in).
#  linux_disk_manager AND wazuh_agent are composed in from the pinned ansible-framework, not
#  vendored — their source of truth is ansible-framework/applications/. Only wazuh_server (the
#  product-specific central stack role) is vendored here.
# --------------------------------------------------------------------------- #
!/ansible/
